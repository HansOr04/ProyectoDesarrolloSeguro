# ============================================================
# Variables de entorno del monorepo ISWZ3206
# Copia este archivo a .env y rellena los valores reales
# NUNCA commitees el .env con secretos reales
# ============================================================

# ============ POSTGRESQL (Triage) ============
POSTGRES_USER=triage_admin
POSTGRES_PASSWORD=triage_secure_password_2024

# ============ MONGODB (compartido Triage + Monetix) ============
MONGO_USER=mongo_admin
MONGO_PASSWORD=mongo_secret_2024
MONGO_EXPRESS_USER=admin
MONGO_EXPRESS_PASS=admin123

# ============ REDIS ============
REDIS_PASSWORD=redis_secret_2024

# ============ RABBITMQ ============
RABBITMQ_USER=rabbit_admin
RABBITMQ_PASSWORD=rabbit_secret_2024

# ============ JWT (sistemas propios, se mantiene para coexistencia) ============
TRIAGE_JWT_SECRET=your-triage-jwt-secret-change-in-production
TRIAGE_JWT_EXPIRES_IN=24h
MONETIX_JWT_SECRET=your-monetix-jwt-secret-change-in-production

# ============ KEYCLOAK ============
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin_secret_2024
KEYCLOAK_DB_USER=keycloak
KEYCLOAK_DB_PASSWORD=keycloak_secret_2024
# URL interna (contenedores → Keycloak)
KEYCLOAK_ISSUER=http://keycloak:8080/realms/universidad
KEYCLOAK_JWKS_URI=http://keycloak:8080/realms/universidad/protocol/openid-connect/certs
# URL externa (browser → Keycloak)
KEYCLOAK_EXTERNAL_URL=http://localhost:8180

# ============ FRONTENDS (Vite — se hornean en build) ============
VITE_TRIAGE_API_URL=http://localhost:8000/api
VITE_MONETIX_API_URL=http://localhost:3001
VITE_KEYCLOAK_URL=http://localhost:8180
VITE_KEYCLOAK_REALM=universidad

# ============ JITSI (teleconsultas Triage) ============
JITSI_DOMAIN=meet.jit.si

# ============ SMTP (opcional — se simula si está vacío) ============
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ============ TWILIO SMS (opcional) ============
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ============ NODE ============
NODE_ENV=development
