# ============================================================
# Variables de entorno del monorepo ISWZ3206
# Copia este archivo a .env y rellena los valores reales
# NUNCA commitees el .env con secretos reales
# ============================================================

# ============ POSTGRESQL (Triage) ============
POSTGRES_USER=triage_admin
POSTGRES_PASSWORD=CHANGE_ME_strong_postgres_password

# ============ MONGODB (compartido Triage + Monetix) ============
MONGO_USER=mongo_admin
MONGO_PASSWORD=CHANGE_ME_strong_mongo_password
MONGO_EXPRESS_USER=admin
MONGO_EXPRESS_PASS=CHANGE_ME_strong_mongo_express_password

# ============ REDIS ============
REDIS_PASSWORD=CHANGE_ME_strong_redis_password

# ============ RABBITMQ ============
RABBITMQ_USER=rabbit_admin
RABBITMQ_PASSWORD=CHANGE_ME_strong_rabbitmq_password

# ============ JWT (sistemas propios, coexistencia con Keycloak) ============
TRIAGE_JWT_SECRET=CHANGE_ME_triage_jwt_secret_min32chars
TRIAGE_JWT_EXPIRES_IN=24h
MONETIX_JWT_SECRET=CHANGE_ME_monetix_jwt_secret_min32chars

# ============ KEYCLOAK ============
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=CHANGE_ME_strong_keycloak_admin_password
KEYCLOAK_DB_USER=keycloak
KEYCLOAK_DB_PASSWORD=CHANGE_ME_strong_keycloak_db_password
# KEYCLOAK_ISSUER debe coincidir con el claim "iss" de los tokens emitidos,
# que usa la URL externa (la que ve el navegador), no el hostname interno de Docker.
KEYCLOAK_ISSUER=http://localhost:8180/realms/universidad
# JWKS sí se resuelve por la red interna de contenedores (servidor -> Keycloak).
KEYCLOAK_JWKS_URI=http://keycloak:8080/realms/universidad/protocol/openid-connect/certs
# URL externa (browser → Keycloak)
KEYCLOAK_EXTERNAL_URL=http://localhost:8180
# OBLIGATORIO cuando KEYCLOAK_JWKS_URI está configurado: identifica al cliente exacto
# que emite los tokens que este servicio acepta. Sin este valor el middleware rechaza
# el arranque para evitar que tokens de otros clientes del mismo realm sean aceptados.
KEYCLOAK_CLIENT_ID=triage-client

# ============ KEYCLOAK CLIENT SECRETS ============
# Asignar via Keycloak Admin Console/API post-deploy — nunca hardcodear en código
TRIAGE_CLIENT_SECRET=CHANGE_ME_generated_triage_client_secret_min32chars
MONETIX_CLIENT_SECRET=CHANGE_ME_generated_monetix_client_secret_min32chars

# ============ FRONTENDS (Vite — se hornean en build) ============
VITE_TRIAGE_API_URL=http://localhost:8000/api
VITE_MONETIX_API_URL=http://localhost:3001/api
VITE_KEYCLOAK_URL=http://localhost:8180
VITE_KEYCLOAK_REALM=universidad

# ============ JITSI Meet (videoconferencias — stack local) ============
JITSI_DOMAIN=localhost:8443
JITSI_PUBLIC_URL=http://localhost:8443
JITSI_BASE_URL=http://localhost:8443
JICOFO_COMPONENT_SECRET=CHANGE_ME_jicofo_component_secret
JICOFO_AUTH_PASSWORD=CHANGE_ME_jicofo_auth_password
JVB_AUTH_PASSWORD=CHANGE_ME_jvb_auth_password
JVB_ADVERTISE_IPS=127.0.0.1

# ============ SMTP — MailHog local (sin envío real) ============
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=

# ============ TWILIO SMS (opcional) ============
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ============ NODE ============
NODE_ENV=development

# ================================================================
# SPRINT 4 — HashiCorp Vault
# ================================================================
VAULT_ADDR=http://localhost:8200
VAULT_ROOT_TOKEN=CHANGE_ME_generated_vault_root_token_min32chars
# Rellenar después de correr docker-compose up vault-init:
VAULT_ROLE_ID=
VAULT_SECRET_ID=
VAULT_TOKEN=

# ================================================================
# SEGURIDAD INTER-SERVICIO
# ================================================================
# nginx inyecta este token en cada request — los servicios lo validan con requireGateway()
INTERNAL_API_SECRET=CHANGE_ME_gateway_token_min64chars_hex
# Clave HMAC-SHA256 para JWT entre microservicios (signServiceRequest / verifyServiceToken)
INTERNAL_SERVICE_SECRET=CHANGE_ME_service_jwt_secret_min64chars_hex

# ================================================================
# FLUJO A→B — Triage → Monetix (Bloqueador 1)
# ================================================================
# URL interna Docker de Monetix (triage-service la usa para enviar reportes cifrados)
MONETIX_BACKEND_URL=http://monetix-backend:4000

# ================================================================
# CORS ORIGINS — dev: localhost; prod: dominio real
# ================================================================
CORS_ORIGIN_TRIAGE=http://localhost:3000
CORS_ORIGIN_MONETIX=http://localhost:5173

# ================================================================
# PRODUCCIÓN — rellenar solo para deploy en VPS/Render
# Dejar vacío en desarrollo
# ================================================================

# Email para certificados Let's Encrypt (Traefik)
ACME_EMAIL=CHANGE_ME_your_email@domain.com

# Hostnames públicos (sin https://, solo el dominio)
KEYCLOAK_HOSTNAME=CHANGE_ME_auth.yourdomain.com
TRIAGE_API_HOSTNAME=CHANGE_ME_api.yourdomain.com
TRIAGE_FRONTEND_HOSTNAME=CHANGE_ME_triage.yourdomain.com
MONETIX_API_HOSTNAME=CHANGE_ME_api-monetix.yourdomain.com
MONETIX_FRONTEND_HOSTNAME=CHANGE_ME_monetix.yourdomain.com

# URLs completas para CORS y Keycloak externo en prod (CON https://)
# CORS_ORIGIN_TRIAGE=https://triage.yourdomain.com
# CORS_ORIGIN_MONETIX=https://monetix.yourdomain.com
# KEYCLOAK_ISSUER=https://auth.yourdomain.com/realms/universidad
# KEYCLOAK_JWKS_URI=https://auth.yourdomain.com/realms/universidad/protocol/openid-connect/certs
# KEYCLOAK_EXTERNAL_URL=https://auth.yourdomain.com

# URLs Vite para rebuild del frontend en prod
# VITE_TRIAGE_API_URL=https://api.yourdomain.com/api
# VITE_MONETIX_API_URL=https://api-monetix.yourdomain.com
# VITE_KEYCLOAK_URL=https://auth.yourdomain.com

# ================================================================
# RATE LIMITING
# ================================================================
AUTH_RATE_LIMIT_MAX=5

# ================================================================
# SPRINT 5 — SonarQube
# ================================================================
SONAR_TOKEN_TRIAGE=
SONAR_TOKEN_MONETIX_BACKEND=
SONAR_TOKEN_MONETIX_FRONTEND=
