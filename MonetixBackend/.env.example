NODE_ENV=development
PORT=3000
MONGO_URI=mongodb://localhost:27017/monetix
MONGO_URI_TEST=mongodb://localhost:27017/monetix-test
JWT_SECRET=your-secret-key-here
JWT_EXPIRES_IN=7d
CORS_ORIGIN=http://localhost:5173

# Keycloak (Sprint 2 — dejar vacío para usar solo JWT propio)
KEYCLOAK_ISSUER=http://localhost:8180/realms/universidad
KEYCLOAK_JWKS_URI=http://localhost:8180/realms/universidad/protocol/openid-connect/certs
# OBLIGATORIO cuando KEYCLOAK_JWKS_URI está configurado. Sin este valor el middleware
# rechaza el arranque del servicio para evitar tokens cruzados entre clientes del realm.
KEYCLOAK_CLIENT_ID=monetix-client